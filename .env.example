# bbox / buffer ウィンドウなどデバッグ表示の有効化（空文字または未設定で無効）
DEBUG=1

# エフェクト: multi / sketch / plotter
EFFECT=plotter

# 記録条件: distance / always
TRIGGER=distance

# カメラデバイスの番号
CAMERA_INDEX=1

# キャプチャ解像度
FRAME_WIDTH=1280
FRAME_HEIGHT=720

# YOLO モデルファイルへのパス（プロジェクトルートからの相対 or 絶対）
MODEL_PATH=models/yolov8n.pt

# 1人あたりの残像バッファ枚数
BUFFER_LENGTH=5

# 同時に保持する人数の上限
MAX_PEOPLE=5
