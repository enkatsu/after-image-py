# bbox / buffer ウィンドウなどデバッグ表示の有効化（空文字または未設定で無効）
DEBUG=1

# エフェクト: multi / sketch / plotter
EFFECT=plotter

# 記録条件: distance / always
TRIGGER=distance

# カメラデバイスの番号
CAMERA_INDEX=1

# キャプチャ解像度
FRAME_WIDTH=1280
FRAME_HEIGHT=720

# YOLO モデルのパス（プロジェクトルートからの相対 or 絶対）。
# 未設定なら models/yolov8n_ncnn_model（NCNN・CPU向け）を優先し、無ければ models/yolov8n.pt（torch）。
# Raspberry Pi など aarch64 では NCNN を使うため、ここは設定しない（コメントアウトのまま）でよい。
# torch 版を明示したい場合のみ次を有効化:
# MODEL_PATH=models/yolov8n.pt

# 1人あたりの残像バッファ枚数
BUFFER_LENGTH=5

# 同時に保持する人数の上限
MAX_PEOPLE=5

# ---- datamosh モード (`python -m after_image.datamosh`) ----

# クリップ mp4 の出力先（プロジェクトルートからの相対 or 絶対）
CLIPS_DIR=clips

# ストックする最大シーン数
MAX_STOCK=5

# 1 シーンの最大長（秒）
SCENE_MAX_SECONDS=5.0

# 検出ゼロが何フレーム連続したらシーン終了とみなすか
SCENE_END_SILENCE_FRAMES=15

# このフレーム数未満のクリップは破棄
SCENE_MIN_FRAMES=30

# データモッシュ済み mp4 の出力先
MOSHED_DIR=moshed

# データモッシュ生成時の fps（concat 元のクリップと揃えること）
MOSHED_FPS=30

# データモッシュのモード切替
#   0    : I-frame 除去（既定）。2 本目以降の絵が前クリップの絵に動きベクトルが乗り、シーン境目で溶ける
#   1 以上 : P-frame 複製。指定フレーム数の動きが反復し、人が消えても動きの軌跡が滲み続ける
MOSH_DELTA=0
